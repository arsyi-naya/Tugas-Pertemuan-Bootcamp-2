generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
  MODERATOR
}

model user {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String  
  role          Role      @default(USER)
  refreshToken  String?   //Nullable - hanya terisi saat user login
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}